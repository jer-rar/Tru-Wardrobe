app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Contains live secrets (Supabase keys/passwords, signing keystore info, API keys) — never commit
z.Notes/

# Supabase CLI local cache (not secrets, just local metadata — no need to version)
supabase/.temp/
